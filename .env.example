# Application
NODE_ENV=development
APP_URL=http://localhost:3000

# Database (MySQL 8)
DATABASE_URL=mysql://computerjobs:computerjobs@localhost:3306/computerjobs

# Redis
REDIS_URL=redis://localhost:6379

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=computerjobs
S3_REGION=us-east-1

# JWT (Phase 1)
JWT_ACCESS_SECRET=change-me-min-32-chars-access-secret-key
JWT_REFRESH_SECRET=change-me-min-32-chars-refresh-secret-key
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
SEED_SUPERADMIN_EMAIL=admin@computerjobs.ir
SEED_SUPERADMIN_PASSWORD=ChangeMe123!

# Logging
LOG_LEVEL=info

